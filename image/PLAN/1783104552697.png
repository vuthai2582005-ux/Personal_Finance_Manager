│   │   ├── UserDAO.java
│   │   ├── AccountDAO.java
│   │   ├── CategoryDAO.java
│   │   ├── TransactionDAO.java
│   │   └── BudgetDAO.java
│   │
│   ├── controller/                        ← CONTROLLER — Xử lý logic nghiệp vụ
