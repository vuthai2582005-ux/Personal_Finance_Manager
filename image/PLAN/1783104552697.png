│   │   ├── DatabaseConnection.java        ← Singleton kết nối SQL Server
│   │   └── AppConstants.java              ← Hằng số ứng dụng
│   │
│   ├── model/                             ← MODEL — POJO / Entity
│   │   ├── User.java
│   │   ├── Account.java
│   │   ├── Category.java
│   │   ├── Transaction.java
│   │   └── Budget.java
│   │
│   ├── dao/                               ← Data Access Object (truy vấn DB)
